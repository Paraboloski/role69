{
  "name": "sheet",
  "productName": "Scheda D&D",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "src/main.cjs",
  "author": "Paraboloski",
  "repository": "https://github.com/Paraboloski/asgaroth_d-d_sheet_apk.git",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "commit": "bash ./git.sh"
  },
  "build": {
    "appId": "com.ver.dndsheet",
    "productName": "Scheda D&D",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main.cjs"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Paraboloski",
        "repo": "asgaroth_d-d_sheet_apk",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.2",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
